# Neo4j credentials
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme123

# LLM (Ollama). Разрешённые в РФ: локальные Qwen; Router.AI — как fallback.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL_SYNTH=qwen2.5:14b-instruct-q5_K_M
OLLAMA_MODEL_TOOL=qwen2.5:3b-instruct-q5_K_M
PREMIUM_MODE=false

# Router.AI (опц. fallback для сложных запросов)
ROUTER_AI_ENABLED=false
ROUTER_AI_API_KEY=

# Корпус
CORPUS_DIR=/data/corpus

# Прочее
LOG_LEVEL=INFO

# --- Провайдер LLM ---
# ollama = локально (нужен GPU + `ollama serve`) | yandex = Yandex AI Studio (без GPU)
LLM_PROVIDER=ollama
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# Модель синтеза / tool. Для open-моделей укажи полный URI из консоли AI Studio,
# напр. gpt://<folder>/deepseek-v3/latest
YANDEX_MODEL_SYNTH=yandexgpt/latest
YANDEX_MODEL_TOOL=yandexgpt-lite/latest
